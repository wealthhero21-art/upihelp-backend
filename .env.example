# Copy to .env for local dev. In production these are set as Coolify env vars.

# From `create-app-db upihelp-backend` on the shared server.
# Host MUST be the Postgres container name, not localhost.
DATABASE_URL=postgres://upihelp_backend:PASSWORD@tod9m3eq8aady2f9ar6z8ciy:5432/upihelp_backend

# Protects all /api/v1/admin/* endpoints. Generate a long random string.
ADMIN_API_KEY=change-me-to-a-long-random-string

# Optional. If set, POST /api/v1/events requires header x-app-key: <this>.
APP_INGEST_KEY=

# Optional server-side Facebook Conversions API. Event forwarding stays
# dormant until BOTH of these are set.
FB_APP_ID=
FB_CAPI_ACCESS_TOKEN=
FB_TEST_EVENT_CODE=

# Server
PORT=3000
HOST=0.0.0.0
CORS_ORIGIN=*
